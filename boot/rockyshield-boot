#!/data/data/com.termux/files/usr/bin/bash
# Termux:Boot startup script for Rocky Shield v2.0
# Place at ~/.termux/boot/rockyshield
# Termux:Boot runs everything in this directory on startup

sleep 15

SHIELD_DIR="$HOME/.rocky-shield"

# Run full scan
"$SHIELD_DIR/rockyshield.sh" full >> "$SHIELD_DIR/logs/boot_scan.log" 2>&1

# Start real-time monitor automatically
nohup "$SHIELD_DIR/monitor.sh" > /dev/null 2>&1 &

# Notification
if command -v termux-notification &>/dev/null; then
  ALERTS=$(grep -c '\[ALERT\]' "$SHIELD_DIR/logs/boot_scan.log" 2>/dev/null || echo 0)
  KILLS=$(grep -c 'KILLED\|QUARANTINED' "$SHIELD_DIR/logs/kills.log" 2>/dev/null || echo 0)
  if [ "$ALERTS" -gt 0 ] || [ "$KILLS" -gt 0 ]; then
    termux-notification \
      --title "🛡️ Shield Boot Scan" \
      --content "$ALERTS alerts, $KILLS killed/quarantined. Monitor active." \
      --priority high --id rockyshield
  else
    termux-notification \
      --title "🛡️ Shield Active" \
      --content "System clean. Real-time monitor running." \
      --priority default --id rockyshield
  fi
fi
